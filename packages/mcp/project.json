{
  "name": "mcp",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/mcp/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/packages/mcp"],
      "options": {
        "outputPath": "dist/packages/mcp",
        "main": "packages/mcp/src/index.ts",
        "tsConfig": "packages/mcp/tsconfig.json",
        "assets": [
          {
            "input": "apps/website/public",
            "glob": "api-docs.json",
            "output": "."
          }
        ]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npm --prefix packages/mcp run smoke"
      }
    }
  }
}
