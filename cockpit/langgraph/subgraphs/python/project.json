{
  "name": "cockpit-langgraph-subgraphs-python",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "cockpit/langgraph/subgraphs/python/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/cockpit/langgraph/subgraphs/python"],
      "options": {
        "outputPath": "dist/cockpit/langgraph/subgraphs/python",
        "main": "cockpit/langgraph/subgraphs/python/src/index.ts",
        "tsConfig": "cockpit/langgraph/subgraphs/python/tsconfig.json"
      }
    },
    "smoke": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "cockpit/langgraph/subgraphs/python",
        "command": "npx tsx -e \"import { langgraphSubgraphsPythonModule } from './src/index.ts'; const module = langgraphSubgraphsPythonModule; if (module.id !== 'langgraph-subgraphs-python' || module.title !== 'LangGraph Subgraphs (Python)') { throw new Error('Unexpected module shape for ' + module.id); }\""
      }
    }
  }
}
