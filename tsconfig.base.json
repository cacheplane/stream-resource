{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "baseUrl": ".",
    "paths": {
      "@cacheplane/cockpit-registry": ["libs/cockpit-registry/src/index.ts"],
      "@cacheplane/stream-resource": ["libs/stream-resource/src/public-api.ts"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022"
  }
}
