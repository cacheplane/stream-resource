{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "outDir": "../../dist/apps/minting-service",
    "emitDeclarationOnly": false,
    "declaration": false
  },
  "include": ["src/**/*.ts", "api/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "api/**/*.spec.ts"]
}
