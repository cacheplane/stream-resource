        "outputPath": "dist/marketing/assets",
        "main": "marketing/assets/src/index.ts",
        "tsConfig": "marketing/assets/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
