{
  "name": "marketing-assets",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "marketing/assets/src",
  "projectType": "library",
  "tags": ["scope:marketing", "type:lib"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/marketing/assets"],
