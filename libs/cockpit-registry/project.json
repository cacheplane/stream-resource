{
  "name": "cockpit-registry",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/cockpit-registry/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/libs/cockpit-registry"],
      "options": {
        "outputPath": "dist/libs/cockpit-registry",
        "main": "libs/cockpit-registry/src/index.ts",
        "tsConfig": "libs/cockpit-registry/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vite:test",
      "options": {
        "configFile": "libs/cockpit-registry/vite.config.mts"
      }
    }
  }
}
