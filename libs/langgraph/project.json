{
  "name": "langgraph",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/langgraph/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [
    "scope:cockpit",
    "scope:cockpit-deploy-smoke",
    "scope:cockpit-e2e",
    "scope:cockpit-examples",
    "scope:cockpit-secret",
    "scope:cockpit-smoke",
    "scope:examples-chat",
    "scope:library",
    "scope:website",
    "scope:website-e2e"
  ],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "project": "libs/langgraph/ng-package.json",
        "tsConfig": "libs/langgraph/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/langgraph/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "libs/langgraph/vite.config.mts"
      }
    }
  }
}
